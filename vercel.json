{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60,
      "excludeFiles": "{backend/**/__pycache__/**,tests/**,*.test.py,__tests__/**,fixtures/**,sample-data/**,docs/**,mobilenetv3_small/exported/model_int8.onnx,mobilenetv3_small/eval/**,mobilenetv3_small/logs/**,**/*.png,**/*.jpg,**/*.csv}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}